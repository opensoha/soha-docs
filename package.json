{
  "name": "soha-docs",
  "private": true,
  "version": "0.1.0",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "next dev --port 3000",
    "start": "next start --port 3000",
    "build": "next build",
    "serve": "next start --port 3000",
    "api:reference:generate": "node scripts/generate-api-reference.mjs",
    "api:reference:check": "node scripts/generate-api-reference.mjs --check",
    "screenshots:check": "node scripts/verify-docs-screenshots.mjs",
    "screenshots:update": "node scripts/verify-docs-screenshots.mjs --update",
    "verify:tutorial-outputs": "node scripts/verify-tutorial-outputs.mjs",
    "typecheck": "tsc --noEmit",
    "test": "npm run api:reference:check && npm run verify:tutorial-outputs && node scripts/verify-ai-gateway-docs.mjs && node scripts/verify-contract-docs.mjs && node scripts/verify-docs-drift.mjs"
  },
  "dependencies": {
    "@mdx-js/react": "^3.0.0",
    "next": "16.2.9",
    "nextra": "4.6.1",
    "nextra-theme-docs": "4.6.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "typescript": "6.0.3"
  },
  "overrides": {
    "zod": "4.3.6"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
